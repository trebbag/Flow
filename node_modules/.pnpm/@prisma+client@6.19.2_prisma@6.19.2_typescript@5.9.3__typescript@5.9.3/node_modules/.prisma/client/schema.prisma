generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RoleName {
  FrontDeskCheckIn
  MA
  Clinician
  FrontDeskCheckOut
  Admin
  RevenueCycle
}

enum EncounterStatus {
  Incoming
  Lobby
  Rooming
  ReadyForProvider
  Optimizing
  CheckOut
  Optimized
}

enum AlertLevel {
  Green
  Yellow
  Red
}

enum TemplateType {
  intake
  rooming
  clinician
  checkout
}

enum ScheduleSource {
  manual
  csv
  fhir
  ehr
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String
  status         String     @default("active")
  phone          String?
  cognitoSub     String?    @unique
  createdAt      DateTime   @default(now())
  roles          UserRole[]
  tasksCreated   Task[]     @relation("TaskCreatedBy")
  tasksCompleted Task[]     @relation("TaskCompletedBy")
}

model Facility {
  id        String   @id @default(uuid())
  name      String
  shortCode String?
  timezone  String   @default("America/New_York")
  status    String   @default("active")
  createdAt DateTime @default(now())

  clinics Clinic[]
  roles   UserRole[]
  reasons ReasonForVisit[]
}

model Clinic {
  id               String  @id @default(uuid())
  facilityId       String?
  name             String
  shortCode        String?
  timezone         String
  status           String  @default("active")
  maRun            Boolean @default(false)
  autoCloseEnabled Boolean @default(false)
  autoCloseTime    String?
  cardColor        String?
  cardTags         Json?

  facility          Facility?             @relation(fields: [facilityId], references: [id])
  providers         Provider[]
  roles             UserRole[]
  reasons           ReasonForVisit[]
  templates         Template[]
  rooms             ClinicRoom[]
  maProviderMaps    MaProviderMap[]
  maClinicMaps      MaClinicMap[]
  incomingSchedules IncomingSchedule[]
  importBatches     IncomingImportBatch[]
  encounters        Encounter[]

  @@index([facilityId])
}

model Provider {
  id       String  @id @default(uuid())
  name     String
  active   Boolean @default(true)
  clinicId String

  clinic            Clinic             @relation(fields: [clinicId], references: [id])
  mappings          MaProviderMap[]
  incomingSchedules IncomingSchedule[]
  encounters        Encounter[]

  @@index([clinicId, active])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  role       RoleName
  clinicId   String?
  facilityId String?

  user     User      @relation(fields: [userId], references: [id])
  clinic   Clinic?   @relation(fields: [clinicId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@unique([userId, role])
  @@index([clinicId])
  @@index([facilityId])
}

model MaProviderMap {
  id         String @id @default(uuid())
  providerId String
  maUserId   String
  clinicId   String

  provider Provider @relation(fields: [providerId], references: [id])
  clinic   Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([providerId, maUserId, clinicId])
  @@index([clinicId])
}

model MaClinicMap {
  id       String @id @default(uuid())
  clinicId String
  maUserId String

  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, maUserId])
  @@index([clinicId])
}

model ClinicRoom {
  id        String  @id @default(uuid())
  clinicId  String
  name      String
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  clinic     Clinic      @relation(fields: [clinicId], references: [id])
  encounters Encounter[]

  @@index([clinicId, active])
}

model ReasonForVisit {
  id         String  @id @default(uuid())
  clinicId   String?
  facilityId String?
  name       String
  active     Boolean @default(true)

  clinic            Clinic?            @relation(fields: [clinicId], references: [id])
  facility          Facility?          @relation(fields: [facilityId], references: [id])
  templates         Template[]
  incomingSchedules IncomingSchedule[]
  encounters        Encounter[]

  @@index([clinicId, active])
  @@index([facilityId, active])
}

model Template {
  id               String       @id @default(uuid())
  clinicId         String?
  reasonForVisitId String
  type             TemplateType
  jsonSchema       Json
  uiSchema         Json
  requiredFields   Json

  clinic Clinic?        @relation(fields: [clinicId], references: [id])
  reason ReasonForVisit @relation(fields: [reasonForVisitId], references: [id])

  @@index([clinicId, reasonForVisitId, type])
}

model IncomingImportBatch {
  id        String         @id @default(uuid())
  clinicId  String
  date      DateTime
  source    ScheduleSource
  fileName  String?
  rowCount  Int            @default(0)
  createdAt DateTime       @default(now())

  clinic   Clinic             @relation(fields: [clinicId], references: [id])
  incoming IncomingSchedule[]
}

model IncomingSchedule {
  id                     String         @id @default(uuid())
  clinicId               String
  dateOfService          DateTime
  patientId              String
  appointmentTime        String?
  appointmentAt          DateTime?
  providerId             String?
  providerLastName       String?
  reasonForVisitId       String?
  reasonText             String?
  source                 ScheduleSource
  rawPayloadJson         Json
  isValid                Boolean        @default(true)
  validationErrors       Json?
  checkedInAt            DateTime?
  checkedInByUserId      String?
  checkedInEncounterId   String?
  dispositionType        String?
  dispositionNote        String?
  dispositionAt          DateTime?
  dispositionByUserId    String?
  dispositionEncounterId String?
  intakeData             Json?
  importBatchId          String?

  clinic      Clinic               @relation(fields: [clinicId], references: [id])
  provider    Provider?            @relation(fields: [providerId], references: [id])
  reason      ReasonForVisit?      @relation(fields: [reasonForVisitId], references: [id])
  importBatch IncomingImportBatch? @relation(fields: [importBatchId], references: [id])

  @@index([clinicId, dateOfService, checkedInAt])
  @@index([dateOfService, patientId, appointmentTime])
}

model Encounter {
  id                 String          @id @default(uuid())
  patientId          String
  clinicId           String
  providerId         String?
  reasonForVisitId   String?
  currentStatus      EncounterStatus
  assignedMaUserId   String?
  roomId             String?
  version            Int             @default(1)
  checkInAt          DateTime?
  dateOfService      DateTime
  roomingStartAt     DateTime?
  roomingCompleteAt  DateTime?
  providerStartAt    DateTime?
  providerEndAt      DateTime?
  checkoutCompleteAt DateTime?
  closedAt           DateTime?
  walkIn             Boolean         @default(false)
  insuranceVerified  Boolean         @default(false)
  arrivalNotes       String?
  closureType        String?
  closureNotes       String?
  roomingData        Json?
  clinicianData      Json?
  checkoutData       Json?
  intakeData         Json?

  clinic       Clinic              @relation(fields: [clinicId], references: [id])
  provider     Provider?           @relation(fields: [providerId], references: [id])
  reason       ReasonForVisit?     @relation(fields: [reasonForVisitId], references: [id])
  room         ClinicRoom?         @relation(fields: [roomId], references: [id])
  statusEvents StatusChangeEvent[]
  alertState   AlertState?
  tasks        Task[]
  safetyEvents SafetyEvent[]

  @@unique([patientId, clinicId, dateOfService])
  @@index([clinicId, currentStatus])
  @@index([clinicId, dateOfService])
}

model StatusChangeEvent {
  id              String           @id @default(uuid())
  encounterId     String
  fromStatus      EncounterStatus?
  toStatus        EncounterStatus
  changedAt       DateTime         @default(now())
  changedByUserId String
  reasonCode      String?

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId, changedAt])
}

model AlertState {
  encounterId           String     @id
  enteredStatusAt       DateTime
  currentAlertLevel     AlertLevel @default(Green)
  yellowTriggeredAt     DateTime?
  redTriggeredAt        DateTime?
  escalationTriggeredAt DateTime?
  lastAckAt             DateTime?

  encounter Encounter @relation(fields: [encounterId], references: [id])
}

model Task {
  id               String    @id @default(uuid())
  encounterId      String
  taskType         String
  description      String
  assignedToRole   RoleName?
  assignedToUserId String?
  status           String    @default("open")
  priority         Int       @default(0)
  blocking         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  createdBy        String
  completedAt      DateTime?
  completedBy      String?

  encounter Encounter @relation(fields: [encounterId], references: [id])
  creator   User      @relation("TaskCreatedBy", fields: [createdBy], references: [id])
  completer User?     @relation("TaskCompletedBy", fields: [completedBy], references: [id])

  @@index([encounterId, status])
}

model SafetyEvent {
  id             String    @id @default(uuid())
  encounterId    String
  activatedAt    DateTime  @default(now())
  activatedBy    String
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  location       String?

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId, resolvedAt])
}

model AlertThreshold {
  id               String          @id @default(uuid())
  clinicId         String
  status           EncounterStatus
  reasonForVisitId String?
  providerId       String?
  yellowAtMin      Int
  redAtMin         Int
  escalation2Min   Int?
}

model NotificationPolicy {
  id                       String          @id @default(uuid())
  clinicId                 String
  status                   EncounterStatus
  severity                 AlertLevel
  recipientsJson           Json
  channelsJson             Json
  cooldownMinutes          Int             @default(10)
  ackRequired              Boolean         @default(false)
  escalationAfterMin       Int?
  escalationRecipientsJson Json?
  quietHoursJson           Json?
}
