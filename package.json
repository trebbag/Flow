{
  "name": "flow-backend",
  "description": "Backend services, operational tooling, and pilot workflows for the Flow clinical operations platform.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm db:push && tsx watch src/server.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "start:all": "node scripts/dev-all.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "pnpm db:push && pnpm build && node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm db:push && vitest run",
    "db:generate": "prisma generate && node scripts/link-prisma-client.mjs",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push:postgres": "tsx scripts/postgres-push.ts",
    "db:push": "tsx scripts/db-init.ts",
    "db:verify:parity": "tsx scripts/verify-schema-parity.ts",
    "phi:backfill": "tsx scripts/phi-encrypt-backfill.ts",
    "retention:enforce": "tsx scripts/retention-enforce.ts",
    "recert:report": "tsx scripts/role-recertification-report.ts",
    "db:seed": "tsx prisma/seed.ts",
    "rollup:daily": "tsx scripts/rollup-daily.ts",
    "db:export:snapshot": "tsx scripts/export-sqlite-snapshot.ts",
    "db:preflight:postgres": "tsx scripts/postgres-preflight.ts",
    "db:import:postgres": "tsx scripts/import-snapshot-postgres.ts",
    "rooms:backfill": "tsx scripts/backfill-room-operational-states.ts",
    "auth:sync:entra": "tsx scripts/sync-entra-pilot-users.ts",
    "auth:sync:directory": "tsx scripts/sync-entra-directory-status.ts",
    "auth:verify:entra-local": "tsx scripts/verify-entra-local.ts",
    "pilot:preflight": "tsx scripts/pilot-preflight.ts",
    "frontend:verify-live": "tsx scripts/frontend-live-verify.ts",
    "pilot:validate:staging": "tsx scripts/staging-validation.ts",
    "staging:auth:refresh": "tsx scripts/refresh-staging-bearer-token.ts",
    "staging:proof:facility-switch": "tsx scripts/staging-facility-switch-proof.ts",
    "staging:proof:threshold-alerts": "tsx scripts/staging-threshold-evidence.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-sqlite3": "^12.6.2",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jose": "^6.1.3",
    "luxon": "^3.7.2",
    "pg": "^8.19.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "prisma": "^7.7.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
