  clinic   Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, dateKey])
  @@index([facilityId, dateKey])
  @@index([dateKey])
  @@index([clinicId, dateKey])
}

model RevenueCycleDailyRollup {
  id                             String   @id @default(uuid())
  facilityId                     String
  clinicId                       String
  dateKey                        String
  sameDayCollectionExpectedVisitCount Int @default(0)
  sameDayCollectionCapturedVisitCount Int @default(0)
  sameDayCollectionExpectedCents Int      @default(0)
  sameDayCollectionTrackedCents  Int      @default(0)
