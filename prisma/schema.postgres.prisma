generator client {
  provider = "prisma-client-js"
  output   = "../generated/postgres-client"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  FrontDeskCheckIn
  MA
  Clinician
  FrontDeskCheckOut
  OfficeManager
  Admin
  RevenueCycle
}

enum EncounterStatus {
  Incoming
  Lobby
  Rooming
  ReadyForProvider
  Optimizing
  CheckOut
  Optimized
}

enum AlertLevel {
  Green
  Yellow
  Red
}

enum AlertThresholdMetric {
  stage
  overall_visit
}

enum TemplateType {
  intake
  rooming
  clinician
  checkout
}

enum ScheduleSource {
  manual
  csv
  fhir
  ehr
}

enum OutboxStatus {
  pending
  dispatched
  failed
}

enum AlertInboxKind {
  threshold
  safety
  task
}

enum AlertInboxStatus {
  active
  archived
}

enum TaskSourceType {
  Encounter
  RoomIssue
  RoomSupplyFlag
  RoomAudit
  RevenueCase
  ProviderClarification
}

enum TaskStatus {
  open
  completed
  archived
}

enum RevenueStatus {
  FinancialReadinessNeeded
  FinanciallyCleared
  CheckoutTrackingNeeded
  ChargeCaptureNeeded
  CodingReviewInProgress
  ProviderClarificationNeeded
  ReadyForAthenaHandoff
  AthenaHandoffInProgress
  AthenaHandoffConfirmed
  MonitoringOnly
  Closed
}

enum RevenueWorkQueue {
  FinancialReadiness
  CheckoutTracking
  ChargeCapture
  ProviderQueries
  AthenaHandoff
  Monitoring
}

enum RevenueDayBucket {
  Today
  Yesterday
  Rolled
  Monitoring
}

enum FinancialEligibilityStatus {
  NotChecked
  Clear
  Blocked
  Pending
}

enum FinancialRequirementStatus {
  NotRequired
  Pending
  Approved
  Expired
  UnableToObtain
}

enum CollectionOutcome {
  CollectedInFull
  CollectedPartial
  NotCollected
  NoCollectionExpected
  Waived
  Deferred
}

enum CodingStage {
  NotStarted
  InProgress
  ReadyForReview
  ReadyForAthena
}

enum ProviderClarificationStatus {
  Open
  Responded
  Resolved
}

enum RevenueChecklistGroup {
  financial_readiness
  checkout_tracking
  charge_capture
  athena_handoff
  athena_monitoring
  registration_demographics
  eligibility_benefits
  patient_estimate_pos
  referral_prior_auth
  encounter_documentation
  charge_capture_coding
  athena_handoff_attestation
  day_close
}

enum RevenueCloseoutState {
  Open
  ClosedResolved
  ClosedUnresolved
  RolledOver
}

enum RoomOperationalStatus {
  Ready
  NotReady
  Occupied
  NeedsTurnover
  Hold
}

enum RoomEventType {
  AssignedToEncounter
  PatientLeftForCheckout
  MarkedReady
  HoldPlaced
  HoldCleared
  IssueCreated
  IssueResolved
  DayStartCompleted
  DayEndCompleted
}

enum RoomHoldReason {
  Equipment
  Maintenance
  Supply
  Audit
  Manual
}

enum RoomIssueType {
  Equipment
  Maintenance
  General
  SupplyLow
  SupplyOut
  AuditFailure
}

enum RoomIssueStatus {
  Open
  Acknowledged
  Resolved
  Dismissed
}

enum RoomChecklistKind {
  DayStart
  DayEnd
}

model User {
  id                        String                              @id @default(uuid())
  email                     String                              @unique
  name                      String
  status                    String                              @default("active")
  phone                     String?
  cognitoSub                String?                             @unique
  entraObjectId             String?                             @unique
  entraTenantId             String?
  entraUserPrincipalName    String?
  identityProvider          String?
  directoryStatus           String?
  directoryUserType         String?
  directoryAccountEnabled   Boolean?
  lastDirectorySyncAt       DateTime?
  activeFacilityId          String?
  createdAt                 DateTime                            @default(now())
  activeFacility            Facility?                           @relation("UserActiveFacility", fields: [activeFacilityId], references: [id], onDelete: SetNull)
  roles                     UserRole[]
  providerAssignments       ClinicAssignment[]                  @relation("ClinicAssignmentProviderUser")
  maAssignments             ClinicAssignment[]                  @relation("ClinicAssignmentMaUser")
  tasksCreated              Task[]                              @relation("TaskCreatedBy")
  tasksCompleted            Task[]                              @relation("TaskCompletedBy")
  tasksAcknowledged         Task[]                              @relation("TaskAcknowledgedBy")
  tasksArchived             Task[]                              @relation("TaskArchivedBy")
  alertInbox                UserAlertInbox[]
  temporaryClinicOverrides  TemporaryClinicAssignmentOverride[] @relation("TemporaryClinicAssignmentUser")
  temporaryOverridesCreated TemporaryClinicAssignmentOverride[] @relation("TemporaryClinicAssignmentCreatedBy")
  temporaryOverridesRevoked TemporaryClinicAssignmentOverride[] @relation("TemporaryClinicAssignmentRevokedBy")
  revenueCasesAssigned      RevenueCase[]                       @relation("RevenueCaseAssignedUser")

  @@index([activeFacilityId])
  @@index([entraTenantId])
  @@index([identityProvider])
}

model Facility {
  id        String   @id @default(uuid())
  name      String
  shortCode String?
  address   String?
  phone     String?
  timezone  String   @default("America/New_York")
  status    String   @default("active")
  createdAt DateTime @default(now())

  clinics                            Clinic[]
  roles                              UserRole[]
  reasons                            ReasonForVisit[]
  templates                          Template[]
  rooms                              ClinicRoom[]
  activeForUsers                     User[]                              @relation("UserActiveFacility")
  alertThresholds                    AlertThreshold[]
  importBatches                      IncomingImportBatch[]
  incomingIssues                     IncomingImportIssue[]
  connectors                         IntegrationConnector[]
  alertInbox                         UserAlertInbox[]
  temporaryClinicAssignmentOverrides TemporaryClinicAssignmentOverride[]
  roomDailyRollups                   RoomDailyRollup[]
  patients                           Patient[]
  patientAliases                     PatientAlias[]
  patientIdentityReviews             PatientIdentityReview[]
  patientConsents                    PatientConsent[]
  revenueCases                       RevenueCase[]
  revenueSettings                    RevenueCycleSettings?
  revenueCloseoutRuns                RevenueCloseoutRun[]
  revenueCycleDailyRollups           RevenueCycleDailyRollup[]
}

model Patient {
  id                        String   @id @default(uuid())
  facilityId                String
  sourcePatientId           String
  normalizedSourcePatientId String
  displayName               String?
  displayNameCipher         String?
  dateOfBirth               DateTime?
  dateOfBirthCipher         String?
  cipherKeyId               String?
  archivedAt                DateTime?
  archivedByUserId          String?
  archivedReason            String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  facility         Facility         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  incomingSchedules IncomingSchedule[]
  encounters       Encounter[]
  revenueCases     RevenueCase[]
  aliases          PatientAlias[]
  identityReviews  PatientIdentityReview[]
  consents         PatientConsent[]

  @@unique([facilityId, normalizedSourcePatientId])
  @@index([facilityId, createdAt])
  @@index([facilityId, dateOfBirth])
}

model PatientAlias {
  id                   String   @id @default(uuid())
  patientId            String
  facilityId           String
  aliasType            String
  aliasValue           String
  normalizedAliasValue String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([patientId, aliasType, normalizedAliasValue])
  @@index([facilityId, aliasType, normalizedAliasValue])
  @@index([patientId, aliasType])
}

model PatientIdentityReview {
  id                        String   @id @default(uuid())
  facilityId                String
  patientId                 String?
  sourcePatientId           String
  normalizedSourcePatientId String
  displayName               String?
  normalizedDisplayName     String?
  dateOfBirth               DateTime?
  reasonCode                String
  status                    String   @default("open")
  matchedPatientIdsJson     Json?
  contextJson               Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  patient  Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([facilityId, status, createdAt])
  @@index([facilityId, normalizedSourcePatientId])
  @@index([patientId, status])
}

model PatientConsent {
  id                 String    @id @default(uuid())
  facilityId         String
  patientId          String
  consentType        String
  grantedAt          DateTime?
  revokedAt          DateTime?
  grantedByUserId    String?
  revokedByUserId    String?
  source             String?
  documentRef        String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, consentType])
  @@index([facilityId, consentType, revokedAt])
}

model Clinic {
  id               String  @id @default(uuid())
  facilityId       String?
  name             String
  shortCode        String?
  timezone         String
  status           String  @default("active")
  maRun            Boolean @default(false)
  autoCloseEnabled Boolean @default(false)
  autoCloseTime    String?
  cardColor        String?
  cardTags         Json?

  facility                     Facility?                           @relation(fields: [facilityId], references: [id])
  providers                    Provider[]
  roles                        UserRole[]
  reasons                      ReasonForVisit[]
  reasonAssignments            ReasonClinicAssignment[]
  templates                    Template[]
  roomAssignments              ClinicRoomAssignment[]
  staffAssignment              ClinicAssignment?
  maProviderMaps               MaProviderMap[]
  maClinicMaps                 MaClinicMap[]
  incomingSchedules            IncomingSchedule[]
  importBatches                IncomingImportBatch[]
  incomingIssues               IncomingImportIssue[]
  encounters                   Encounter[]
  officeManagerDailyRollups    OfficeManagerDailyRollup[]
  roomDailyRollups             RoomDailyRollup[]
  revenueCases                 RevenueCase[]
  revenueCloseoutRuns          RevenueCloseoutRun[]
  revenueCycleDailyRollups     RevenueCycleDailyRollup[]
  alertInbox                   UserAlertInbox[]
  temporaryAssignmentOverrides TemporaryClinicAssignmentOverride[]
  notificationPolicies         NotificationPolicy[]

  @@index([facilityId])
}

model Provider {
  id       String  @id @default(uuid())
  name     String
  active   Boolean @default(true)
  clinicId String

  clinic            Clinic             @relation(fields: [clinicId], references: [id])
  mappings          MaProviderMap[]
  clinicAssignments ClinicAssignment[]
  incomingSchedules IncomingSchedule[]
  encounters        Encounter[]
  revenueCases      RevenueCase[]

  @@index([clinicId, active])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  role       RoleName
  clinicId   String?
  facilityId String?

  user     User      @relation(fields: [userId], references: [id])
  clinic   Clinic?   @relation(fields: [clinicId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@unique([userId, role, clinicId, facilityId])
  @@index([clinicId])
  @@index([facilityId])
}

model MaProviderMap {
  id         String @id @default(uuid())
  providerId String
  maUserId   String
  clinicId   String

  provider Provider @relation(fields: [providerId], references: [id])
  clinic   Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([providerId, maUserId, clinicId])
  @@index([clinicId])
}

model MaClinicMap {
  id       String @id @default(uuid())
  clinicId String
  maUserId String

  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, maUserId])
  @@index([clinicId])
}

model ClinicAssignment {
  id             String   @id @default(uuid())
  clinicId       String   @unique
  providerUserId String?
  providerId     String?
  maUserId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic       Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  providerUser User?     @relation("ClinicAssignmentProviderUser", fields: [providerUserId], references: [id])
  provider     Provider? @relation(fields: [providerId], references: [id])
  maUser       User?     @relation("ClinicAssignmentMaUser", fields: [maUserId], references: [id])

  @@index([clinicId])
  @@index([providerUserId])
  @@index([providerId])
  @@index([maUserId])
}

model TemporaryClinicAssignmentOverride {
  id              String    @id @default(uuid())
  userId          String
  role            RoleName
  clinicId        String
  facilityId      String
  startsAt        DateTime
  endsAt          DateTime
  reason          String
  createdByUserId String
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?
  revokedByUserId String?

  user      User     @relation("TemporaryClinicAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  facility  Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  createdBy User     @relation("TemporaryClinicAssignmentCreatedBy", fields: [createdByUserId], references: [id])
  revokedBy User?    @relation("TemporaryClinicAssignmentRevokedBy", fields: [revokedByUserId], references: [id])

  @@index([userId, role, startsAt, endsAt])
  @@index([clinicId, startsAt, endsAt])
  @@index([facilityId, startsAt, endsAt])
  @@index([revokedAt])
}

model ClinicRoom {
  id         String @id @default(uuid())
  facilityId String
  name       String
  roomNumber Int    @default(0)
  roomType   String @default("exam")
  status     String @default("active")
  sortOrder  Int    @default(0)

  facility          Facility               @relation(fields: [facilityId], references: [id])
  clinicLinks       ClinicRoomAssignment[]
  encounters        Encounter[]
  operationalState  RoomOperationalState?
  operationalEvents RoomOperationalEvent[]
  roomIssues        RoomIssue[]
  checklistRuns     RoomChecklistRun[]
  tasks             Task[]

  // Active/inactive room-number uniqueness is enforced with a partial unique index in scripts/db-init.ts.
  @@index([facilityId, status])
  @@index([facilityId, roomNumber])
}

model ClinicRoomAssignment {
  id        String   @id @default(uuid())
  clinicId  String
  roomId    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  room   ClinicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([clinicId, roomId])
  @@index([clinicId, active])
  @@index([roomId, active])
}

model ReasonForVisit {
  id                       String  @id @default(uuid())
  clinicId                 String?
  facilityId               String?
  name                     String
  appointmentLengthMinutes Int     @default(20)
  status                   String  @default("active")
  active                   Boolean @default(true)

  clinic              Clinic?                    @relation(fields: [clinicId], references: [id])
  facility            Facility?                  @relation(fields: [facilityId], references: [id])
  templates           Template[]                 @relation("LegacyTemplateReason")
  clinicAssignments   ReasonClinicAssignment[]
  templateAssignments TemplateReasonAssignment[]
  incomingSchedules   IncomingSchedule[]
  encounters          Encounter[]

  @@index([clinicId, status])
  @@index([facilityId, status])
  @@index([facilityId, active])
}

model Template {
  id               String       @id @default(uuid())
  facilityId       String
  name             String
  status           String       @default("active")
  active           Boolean      @default(true)
  fieldsJson       Json         @default("[]")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  clinicId         String?
  reasonForVisitId String?
  type             TemplateType
  jsonSchema       Json
  uiSchema         Json
  requiredFields   Json
  schemaVersion    Int          @default(1)

  facility          Facility                   @relation(fields: [facilityId], references: [id])
  clinic            Clinic?                    @relation(fields: [clinicId], references: [id])
  reason            ReasonForVisit?            @relation("LegacyTemplateReason", fields: [reasonForVisitId], references: [id])
  reasonAssignments TemplateReasonAssignment[]

  @@index([facilityId, status, type])
  @@index([clinicId, type])
  @@index([reasonForVisitId, type])
}

model ReasonClinicAssignment {
  id        String   @id @default(uuid())
  reasonId  String
  clinicId  String
  createdAt DateTime @default(now())

  reason ReasonForVisit @relation(fields: [reasonId], references: [id], onDelete: Cascade)
  clinic Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([reasonId, clinicId])
  @@index([clinicId])
}

model TemplateReasonAssignment {
  id         String   @id @default(uuid())
  templateId String
  reasonId   String
  createdAt  DateTime @default(now())

  template Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  reason   ReasonForVisit @relation(fields: [reasonId], references: [id], onDelete: Cascade)

  @@unique([templateId, reasonId])
  @@index([reasonId])
}

model IncomingImportBatch {
  id               String         @id @default(uuid())
  facilityId       String
  clinicId         String?
  date             DateTime
  source           ScheduleSource
  fileName         String?
  rowCount         Int            @default(0)
  acceptedRowCount Int            @default(0)
  pendingRowCount  Int            @default(0)
  status           String         @default("processed")
  createdAt        DateTime       @default(now())

  facility Facility              @relation(fields: [facilityId], references: [id])
  clinic   Clinic?               @relation(fields: [clinicId], references: [id])
  incoming IncomingSchedule[]
  issues   IncomingImportIssue[]

  @@index([facilityId, date, status])
  @@index([clinicId, date, status])
}

model IncomingSchedule {
  id                     String         @id @default(uuid())
  clinicId               String
  patientRecordId        String?
  dateOfService          DateTime
  patientId              String
  appointmentTime        String?
  appointmentAt          DateTime?
  providerId             String?
  providerLastName       String?
  reasonForVisitId       String?
  reasonText             String?
  source                 ScheduleSource
  rawPayloadJson         Json
  isValid                Boolean        @default(true)
  validationErrors       Json?
  checkedInAt            DateTime?
  checkedInByUserId      String?
  checkedInEncounterId   String?
  dispositionType        String?
  dispositionNote        String?
  dispositionAt          DateTime?
  dispositionByUserId    String?
  dispositionEncounterId String?
  intakeData             Json?
  importBatchId          String?

  clinic         Clinic                @relation(fields: [clinicId], references: [id])
  patientRecord  Patient?              @relation(fields: [patientRecordId], references: [id])
  provider       Provider?             @relation(fields: [providerId], references: [id])
  reason         ReasonForVisit?       @relation(fields: [reasonForVisitId], references: [id])
  importBatch    IncomingImportBatch?  @relation(fields: [importBatchId], references: [id])
  resolvedIssues IncomingImportIssue[]

  @@index([clinicId, dateOfService, checkedInAt])
  @@index([dateOfService, patientId, appointmentTime])
  @@index([patientRecordId])
}

model IncomingImportIssue {
  id                 String   @id @default(uuid())
  batchId            String
  facilityId         String
  clinicId           String?
  dateOfService      DateTime
  rawPayloadJson     Json
  normalizedJson     Json?
  validationErrors   Json
  status             String   @default("pending")
  retryCount         Int      @default(0)
  resolvedIncomingId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  batch            IncomingImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  facility         Facility            @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clinic           Clinic?             @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  resolvedIncoming IncomingSchedule?   @relation(fields: [resolvedIncomingId], references: [id], onDelete: SetNull)

  @@index([batchId, status])
  @@index([facilityId, dateOfService, status])
  @@index([clinicId, status])
}

model Encounter {
  id                 String          @id @default(uuid())
  patientId          String
  patientRecordId    String?
  clinicId           String
  providerId         String?
  reasonForVisitId   String?
  currentStatus      EncounterStatus
  assignedMaUserId   String?
  roomId             String?
  version            Int             @default(1)
  checkInAt          DateTime?
  dateOfService      DateTime
  roomingStartAt     DateTime?
  roomingCompleteAt  DateTime?
  providerStartAt    DateTime?
  providerEndAt      DateTime?
  checkoutCompleteAt DateTime?
  closedAt           DateTime?
  walkIn             Boolean         @default(false)
  insuranceVerified  Boolean         @default(false)
  arrivalNotes       String?
  closureType        String?
  closureNotes       String?
  archivedAt         DateTime?
  archivedByUserId   String?
  archivedReason     String?
  roomingData        Json?
  clinicianData      Json?
  checkoutData       Json?
  intakeData         Json?

  clinic                 Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  patientRecord          Patient?               @relation(fields: [patientRecordId], references: [id], onDelete: SetNull)
  provider               Provider?              @relation(fields: [providerId], references: [id], onDelete: SetNull)
  reason                 ReasonForVisit?        @relation(fields: [reasonForVisitId], references: [id], onDelete: SetNull)
  room                   ClinicRoom?            @relation(fields: [roomId], references: [id], onDelete: SetNull)
  statusEvents           StatusChangeEvent[]
  alertState             AlertState?
  tasks                  Task[]
  revenueCase            RevenueCase?
  providerClarifications ProviderClarification[]
  safetyEvents           SafetyEvent[]
  operationalOccupancies RoomOperationalState[] @relation("RoomOperationalEncounter")
  roomOperationalEvents  RoomOperationalEvent[]
  roomIssues             RoomIssue[]

  @@unique([patientId, clinicId, dateOfService])
  @@index([clinicId, currentStatus])
  @@index([clinicId, dateOfService])
  @@index([patientRecordId])
}

model StatusChangeEvent {
  id              String           @id @default(uuid())
  encounterId     String
  fromStatus      EncounterStatus?
  toStatus        EncounterStatus
  changedAt       DateTime         @default(now())
  changedByUserId String
  reasonCode      String?

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId, changedAt])
}

model EntityEvent {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  eventType     String
  actorUserId   String?
  facilityId    String?
  clinicId      String?
  requestId     String?
  beforeJson    Json?
  afterJson     Json?
  metadataJson  Json?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([facilityId, createdAt])
  @@index([actorUserId, createdAt])
}

model AlertState {
  encounterId           String     @id
  enteredStatusAt       DateTime
  currentAlertLevel     AlertLevel @default(Green)
  yellowTriggeredAt     DateTime?
  redTriggeredAt        DateTime?
  escalationTriggeredAt DateTime?
  lastAckAt             DateTime?

  encounter Encounter @relation(fields: [encounterId], references: [id])
}

model Task {
  id               String          @id @default(uuid())
  facilityId       String?
  clinicId         String?
  encounterId      String?
  roomId           String?
  revenueCaseId    String?
  sourceType       TaskSourceType?
  sourceId         String?
  taskCategory     String?
  taskType         String
  description      String
  assignedToRole   RoleName?
  assignedToUserId String?
  status           TaskStatus      @default(open)
  priority         Int             @default(0)
  blocking         Boolean         @default(false)
  dueAt            DateTime?
  createdAt        DateTime        @default(now())
  createdBy        String
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  completedAt      DateTime?
  completedBy      String?
  archivedAt       DateTime?
  archivedByUserId String?         @map("archivedBy")
  notes            String?
  version          Int             @default(0)
  updatedAt        DateTime        @default(now()) @updatedAt

  encounter    Encounter?  @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  room         ClinicRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  revenueCase  RevenueCase? @relation(fields: [revenueCaseId], references: [id], onDelete: SetNull)
  creator      User        @relation("TaskCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  acknowledger User?       @relation("TaskAcknowledgedBy", fields: [acknowledgedBy], references: [id], onDelete: SetNull)
  completer    User?       @relation("TaskCompletedBy", fields: [completedBy], references: [id], onDelete: SetNull)
  archiver     User?       @relation("TaskArchivedBy", fields: [archivedByUserId], references: [id], onDelete: SetNull)
  roomIssues   RoomIssue[]

  @@index([clinicId, status, createdAt])
  @@index([roomId, status, createdAt])
  @@index([encounterId, status])
  @@index([revenueCaseId, status])
  @@index([assignedToRole, status])
}

model RevenueCase {
  id                       String            @id @default(uuid())
  encounterId              String            @unique
  facilityId               String
  clinicId                 String
  patientId                String
  patientRecordId          String?
  providerId               String?
  dateOfService            DateTime
  currentRevenueStatus     RevenueStatus     @default(FinancialReadinessNeeded)
  currentWorkQueue         RevenueWorkQueue  @default(FinancialReadiness)
  currentDayBucket         RevenueDayBucket  @default(Today)
  priority                 Int               @default(0)
  assignedToUserId         String?
  assignedToRole           RoleName?
  currentBlockerCategory   String?
  currentBlockerText       String?
  dueAt                    DateTime?
  rolledFromDateKey        String?
  rollReason               String?
  readyForAthenaAt         DateTime?
  athenaHandoffOwnerUserId String?
  athenaHandoffStartedAt   DateTime?
  athenaHandoffConfirmedAt DateTime?
  athenaHandoffConfirmedByUserId String?
  athenaHandoffNote        String?
  athenaChargeEnteredAt    DateTime?
  athenaClaimSubmittedAt   DateTime?
  athenaDaysToSubmit       Float?
  athenaDaysInAR           Float?
  athenaClaimStatus        String?
  athenaPatientBalanceCents Int?
  athenaLastSyncAt         DateTime?
  closeoutState            RevenueCloseoutState @default(Open)
  closedAt                 DateTime?
  archivedAt               DateTime?
  archivedByUserId         String?
  archivedReason           String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  encounter                  Encounter                    @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  facility                   Facility                     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clinic                     Clinic                       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patientRecord              Patient?                     @relation(fields: [patientRecordId], references: [id])
  provider                   Provider?                    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  assignedToUser             User?                        @relation("RevenueCaseAssignedUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  financialReadiness         FinancialReadiness?
  checkoutCollectionTracking CheckoutCollectionTracking?
  chargeCaptureRecord        ChargeCaptureRecord?
  providerClarifications     ProviderClarification[]
  checklistItems             RevenueChecklistItem[]
  events                     RevenueCaseEvent[]
  closeoutItems              RevenueCloseoutItem[]
  tasks                      Task[]

  @@index([facilityId, currentDayBucket, currentWorkQueue])
  @@index([clinicId, dateOfService])
  @@index([clinicId, currentRevenueStatus, currentDayBucket])
  @@index([assignedToUserId, currentRevenueStatus])
  @@index([assignedToRole, currentRevenueStatus])
  @@index([closeoutState, currentDayBucket])
  @@index([patientRecordId])
}

model FinancialReadiness {
  revenueCaseId                  String                    @id
  eligibilityStatus              FinancialEligibilityStatus @default(NotChecked)
  verifiedAt                     DateTime?
  verifiedByUserId               String?
  registrationVerified           Boolean                   @default(false)
  contactInfoVerified            Boolean                   @default(false)
  primaryPayerName               String?
  primaryPlanName                String?
  secondaryPayerName             String?
  financialClass                 String?
  benefitsSummaryText            String?
  patientEstimateAmountCents     Int                       @default(0)
  pointOfServiceAmountDueCents   Int                       @default(0)
  estimateExplainedToPatient     Boolean                   @default(false)
  outstandingPriorBalanceCents   Int                       @default(0)
  coverageIssueCategory          String?
  coverageIssueText              String?
  referralRequired               Boolean                   @default(false)
  referralStatus                 FinancialRequirementStatus @default(NotRequired)
  priorAuthRequired              Boolean                   @default(false)
  priorAuthStatus                FinancialRequirementStatus @default(NotRequired)
  priorAuthNumber                String?
  notesJson                      Json?

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)
}

model CheckoutCollectionTracking {
  revenueCaseId           String            @id
  collectionExpected      Boolean           @default(false)
  amountDueCents          Int               @default(0)
  amountCollectedCents    Int               @default(0)
  collectionOutcome       CollectionOutcome?
  missedCollectionReason  String?
  trackingNote            String?
  trackedByUserId         String?
  trackedAt               DateTime?
  sourceFieldJson         Json?

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)
}

model ChargeCaptureRecord {
  revenueCaseId          String      @id
  documentationComplete  Boolean     @default(false)
  codingStage            CodingStage @default(NotStarted)
  icd10CodesJson         Json?
  procedureLinesJson     Json?
  serviceCaptureItemsJson Json?
  documentationSummaryJson Json?
  cptCodesJson           Json?
  modifiersJson          Json?
  unitsJson              Json?
  codingNote             String?
  reviewedByUserId       String?
  reviewedAt             DateTime?
  readyForAthenaAt       DateTime?

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)
}

model ProviderClarification {
  id                String                     @id @default(uuid())
  revenueCaseId     String
  encounterId       String
  requestedByUserId String
  targetUserId      String?
  queryType         String?
  questionText      String
  responseText      String?
  status            ProviderClarificationStatus @default(Open)
  openedAt          DateTime                   @default(now())
  respondedAt       DateTime?
  resolvedAt        DateTime?

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)
  encounter   Encounter   @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([revenueCaseId, status, openedAt])
  @@index([encounterId, status])
  @@index([targetUserId, status])
}

model RevenueChecklistItem {
  id                String               @id @default(uuid())
  revenueCaseId     String
  group             RevenueChecklistGroup
  label             String
  required          Boolean              @default(true)
  status            String               @default("pending")
  sortOrder         Int                  @default(0)
  dueAt             DateTime?
  completedAt       DateTime?
  completedByUserId String?
  evidenceText      String?
  payloadJson       Json?

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)

  @@index([revenueCaseId, group, status])
}

model RevenueCaseEvent {
  id            String         @id @default(uuid())
  revenueCaseId String
  eventType     String
  fromStatus    RevenueStatus?
  toStatus      RevenueStatus?
  actorUserId   String?
  eventText     String?
  payloadJson   Json?
  createdAt     DateTime       @default(now())

  revenueCase RevenueCase @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)

  @@index([revenueCaseId, createdAt])
}

model RevenueCycleSettings {
  facilityId                  String   @id
  missedCollectionReasonsJson Json
  queueSlaJson                Json
  dayCloseDefaultsJson        Json
  estimateDefaultsJson        Json?
  providerQueryTemplatesJson  Json
  athenaLinkTemplate          String?
  athenaChecklistDefaultsJson Json
  checklistDefaultsJson       Json
  serviceCatalogJson          Json
  chargeScheduleJson          Json
  reimbursementRulesJson      Json?
  schemaVersion               Int      @default(1)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

model RevenueCloseoutRun {
  id              String   @id @default(uuid())
  facilityId      String
  clinicId        String
  dateKey         String
  closedByUserId  String?
  unresolvedCount Int      @default(0)
  rolledCount     Int      @default(0)
  note            String?
  createdAt       DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clinic   Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  items    RevenueCloseoutItem[]

  @@index([facilityId, dateKey])
  @@index([clinicId, dateKey])
}

model RevenueCloseoutItem {
  id                 String           @id @default(uuid())
  closeoutRunId      String
  revenueCaseId      String
  queue              RevenueWorkQueue
  snapshotStatus     RevenueStatus
  ownerUserId        String?
  ownerRole          RoleName?
  reasonNotCompleted String
  nextAction         String?
  dueAt              DateTime?
  rollover           Boolean          @default(false)
  patientId          String
  providerId         String?
  createdAt          DateTime         @default(now())

  closeoutRun RevenueCloseoutRun @relation(fields: [closeoutRunId], references: [id], onDelete: Cascade)
  revenueCase RevenueCase        @relation(fields: [revenueCaseId], references: [id], onDelete: Cascade)

  @@index([closeoutRunId])
  @@index([revenueCaseId])
  @@index([queue, rollover])
}

model RoomOperationalState {
  roomId              String                @id
  currentStatus       RoomOperationalStatus @default(Ready)
  statusSinceAt       DateTime              @default(now())
  occupiedEncounterId String?
  activeCleanerUserId String?
  holdReason          RoomHoldReason?
  holdNote            String?
  lastReadyAt         DateTime?
  lastOccupiedAt      DateTime?
  lastTurnoverAt      DateTime?
  updatedAt           DateTime              @updatedAt

  room              ClinicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  occupiedEncounter Encounter? @relation("RoomOperationalEncounter", fields: [occupiedEncounterId], references: [id], onDelete: SetNull)

  @@index([currentStatus, statusSinceAt])
  @@index([occupiedEncounterId])
}

model RoomOperationalEvent {
  id              String                 @id @default(uuid())
  roomId          String
  clinicId        String
  facilityId      String
  encounterId     String?
  eventType       RoomEventType
  fromStatus      RoomOperationalStatus?
  toStatus        RoomOperationalStatus?
  note            String?
  metadataJson    Json?
  createdByUserId String?
  occurredAt      DateTime               @default(now())

  room      ClinicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  @@index([roomId, occurredAt])
  @@index([clinicId, occurredAt])
  @@index([encounterId])
}

model RoomIssue {
  id               String          @id @default(uuid())
  roomId           String
  clinicId         String
  facilityId       String
  encounterId      String?
  issueType        RoomIssueType
  status           RoomIssueStatus @default(Open)
  severity         Int             @default(0)
  title            String
  description      String?
  placesRoomOnHold Boolean         @default(false)
  taskId           String?
  sourceModule     String?
  metadataJson     Json?
  version          Int             @default(0)
  updatedAt        DateTime        @default(now()) @updatedAt
  createdAt        DateTime        @default(now())
  createdByUserId  String
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?

  room      ClinicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  encounter Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([roomId, status, createdAt])
  @@index([clinicId, status, createdAt])
  @@index([taskId])
}

model RoomChecklistRun {
  id                String            @id @default(uuid())
  roomId            String
  clinicId          String
  facilityId        String
  kind              RoomChecklistKind
  dateKey           String
  itemsJson         Json
  completed         Boolean           @default(false)
  startedAt         DateTime          @default(now())
  completedAt       DateTime?
  completedByUserId String?
  note              String?

  room ClinicRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, kind, dateKey])
  @@index([clinicId, kind, dateKey])
}

model UserAlertInbox {
  id               String           @id @default(uuid())
  userId           String
  facilityId       String
  clinicId         String?
  kind             AlertInboxKind
  sourceId         String
  sourceVersionKey String
  title            String
  message          String
  payloadJson      Json?
  status           AlertInboxStatus @default(active)
  createdAt        DateTime         @default(now())
  acknowledgedAt   DateTime?
  archivedAt       DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  clinic   Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@unique([userId, kind, sourceVersionKey])
  @@index([userId, status, createdAt])
  @@index([facilityId, clinicId, kind, status])
}

model SafetyEvent {
  id             String    @id @default(uuid())
  encounterId    String
  activatedAt    DateTime  @default(now())
  activatedBy    String
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?
  location       String?

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId, resolvedAt])
}

model AlertThreshold {
