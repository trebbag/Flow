  ackRequired              Boolean         @default(false)
  escalationAfterMin       Int?
  escalationRecipientsJson Json?
  quietHoursJson           Json?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, severity])
}

model OfficeManagerDailyRollup {
