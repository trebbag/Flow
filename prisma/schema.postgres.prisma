model AuditLog {
  id          String    @id @default(uuid())
  requestId   String
  idempotencyKey String?
  occurredAt  DateTime  @default(now())
  actorUserId String?
  actorRole   RoleName?
  authSource  String?
  method      String
  route       String
  statusCode  Int
  clinicId    String?
  facilityId  String?
  entityType  String?
  entityId    String?
  payloadJson Json?

  @@index([occurredAt])
  @@index([requestId])
  @@index([route, method])
  @@index([facilityId, occurredAt])
  @@index([clinicId, occurredAt])
  @@index([idempotencyKey])
}

model IdempotencyRecord {
  id             String   @id @default(uuid())
  actorUserId    String
  method         String
  routeKey       String
  idempotencyKey String
  requestHash    String
  statusCode     Int
  responseJson   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([actorUserId, method, routeKey, idempotencyKey])
  @@index([routeKey, createdAt])
}

model EventOutbox {
  id            String       @id @default(uuid())
  topic         String
  eventType     String
  aggregateType String?
  aggregateId   String?
  requestId     String?
  payloadJson   Json
  status        OutboxStatus @default(pending)
  attempts      Int          @default(0)
  createdAt     DateTime     @default(now())
  dispatchedAt  DateTime?
  lastError     String?

  @@index([status, createdAt])
  @@index([topic, createdAt])
  @@index([aggregateType, aggregateId])
}

model WorkerLease {
  id              String   @id @default(uuid())
  leaseKey        String   @unique
  ownerId         String
  acquiredAt      DateTime @default(now())
  expiresAt       DateTime
  lastHeartbeatAt DateTime @default(now())
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
  @@index([ownerId, expiresAt])
}

model IntegrationConnector {
  id              String    @id @default(uuid())
  facilityId      String
  vendor          String
  enabled         Boolean   @default(false)
  configJson      Json
  mappingJson     Json?
  lastTestStatus  String?
  lastTestAt      DateTime?
  lastTestMessage String?
  lastSyncStatus  String?
  lastSyncAt      DateTime?
  lastSyncMessage String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, vendor])
  @@index([vendor, enabled])
}
