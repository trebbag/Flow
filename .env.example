# SQLite for local development; switch to PostgreSQL for production pilot.
DATABASE_URL="file:./prisma/dev.db"
POSTGRES_DATABASE_URL=postgresql://flow:flow@localhost:5432/flow
PILOT_API_BASE_URL=

# Server configuration
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute
TRUST_PROXY=false

# Auth configuration (development defaults)
AUTH_MODE=hybrid
AUTH_ALLOW_DEV_HEADERS=true
AUTH_ALLOW_IMPLICIT_ADMIN=false
ENTRA_STRICT_MODE=false
ENTRA_TENANT_ID=
ENTRA_GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
ENTRA_GRAPH_SCOPE=https://graph.microsoft.com/.default
ENTRA_GRAPH_MANAGED_IDENTITY_CLIENT_ID=
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=flow.local
JWT_AUDIENCE=flow-web
JWT_SUBJECT_CLAIMS=sub,oid,objectidentifier
JWT_JWKS_URI=

# Pilot/staging auth hardening (recommended):
# AUTH_MODE=jwt
# AUTH_ALLOW_DEV_HEADERS=false
# AUTH_ALLOW_IMPLICIT_ADMIN=false
# ENTRA_STRICT_MODE=true
# ENTRA_TENANT_ID=<tenant-id>
# ENTRA_GRAPH_MANAGED_IDENTITY_CLIENT_ID=<managed-identity-client-id-if-using-user-assigned-mi>
# JWT_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
# JWT_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# JWT_AUDIENCE=api://<backend-api-app-id>

# Optional local sync values for Microsoft Entra pilot users
ENTRA_EMAIL_ADMIN=
ENTRA_OID_ADMIN=
ENTRA_EMAIL_FRONTDESKCHECKIN=
ENTRA_OID_FRONTDESKCHECKIN=
ENTRA_EMAIL_MA=
ENTRA_OID_MA=
ENTRA_EMAIL_CLINICIAN=
ENTRA_OID_CLINICIAN=
ENTRA_EMAIL_FRONTDESKCHECKOUT=
ENTRA_OID_FRONTDESKCHECKOUT=
ENTRA_EMAIL_REVENUECYCLE=
ENTRA_OID_REVENUECYCLE=

# Frontend auth runtime flags (docs/Flow Frontend)
# VITE_ENABLE_DEV_HEADERS=true
# VITE_ENABLE_DEV_HEADER_LOGIN=true
# VITE_DEFAULT_AUTH_MODE=dev_header

# Safety assist confirmation word
SAFETY_WORD=ANCHOR

# AthenaOne connector defaults (network hardening)
ATHENA_TIMEOUT_MS=7000
ATHENA_RETRY_COUNT=2
ATHENA_RETRY_BACKOFF_MS=400
